# Copy to .env (never commit .env). Used by: npm run api

SMTP_HOST=roadwiseconsulting.com
SMTP_PORT=465
SMTP_USER=contact@roadwiseconsulting.com
SMTP_PASS=

# Where form submissions are delivered (defaults to SMTP_USER if unset)
CONTACT_TO_EMAIL=contact@roadwiseconsulting.com

# Local API port (Vite dev proxies /api here)
CONTACT_API_PORT=3001
